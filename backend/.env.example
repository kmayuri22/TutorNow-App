# TutorNow Backend — Environment Variables
# Copy this file to .env and fill in values

# JWT Secret Key (use a strong random string in production)
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Token expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database URL
# For local development:
DATABASE_URL=sqlite:///./tutornow.db
# For Render PostgreSQL (set automatically by render.yaml):
# DATABASE_URL=postgresql://user:password@host/dbname

# CORS Origins (comma-separated in production)
# ALLOWED_ORIGINS=https://tutornow-app.vercel.app
